<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_tw_report_note" model="ir.ui.view">
        <field name="name">account.move.form.tw.report.note</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="tw_report_note"
                       placeholder="例如：PO260414113680"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
            </xpath>
        </field>
    </record>
</odoo>
